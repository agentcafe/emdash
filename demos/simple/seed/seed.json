							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "Founded in 2024, we've helped thousands of professionals find their next role at companies ranging from early-stage startups to Fortune 500 enterprises."
								}
							]
						}
					]
				}
			}
