					"title": "Categories"
				},
				{
					"type": "component",
					"componentId": "core:recent-posts",
					"title": "Recent Jobs",
					"settings": { "count": 5, "showDate": true }
				}
			]
		},
		{
			"name": "footer",
			"label": "Footer",
			"description": "Widget area displayed in the site footer",
			"widgets": [
				{
					"type": "content",
					"title": "About TechHire",
					"content": [
						{
							"_type": "block",
							"style": "normal",
							"children": [
								{
									"_type": "span",
									"text": "TechHire connects talented tech professionals with great companies. We believe the right role changes everything."
								}
							]
						}
					]
				}
			]
		}
	],

