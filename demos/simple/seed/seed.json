{
	"$schema": "https://emdashcms.com/seed.schema.json",
	"version": "1",
	"meta": {
		"name": "TechHire",
		"description": "A modern tech job board",
		"author": "TechHire"
	},

	"settings": {
		"title": "TechHire",
		"tagline": "Find your next tech role"
	},

	"collections": [
		{
			"slug": "jobs",
			"label": "Jobs",
			"labelSingular": "Job",
			"supports": ["drafts", "revisions", "search", "seo"],
			"commentsEnabled": false,
			"fields": [
				{
					"slug": "title",
					"label": "Job Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "company",
					"label": "Company",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "location",
					"label": "Location",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "salary",
					"label": "Salary Range",
					"type": "string",
					"searchable": false
				},
				{
					"slug": "type",
					"label": "Employment Type",
					"type": "string",
					"required": true,
					"searchable": false
				},
				{
					"slug": "category",
					"label": "Category",
					"type": "string",
					"required": true,
					"searchable": false
				},
				{
					"slug": "experience_level",
					"label": "Experience Level",
					"type": "string",
					"searchable": false
				},
				{
					"slug": "description",
					"label": "Job Description",
					"type": "portableText",
					"searchable": true
				},
				{
					"slug": "tags",
					"label": "Tags",
					"type": "json",
					"searchable": false
				},
				{
					"slug": "is_remote",
					"label": "Remote",
					"type": "boolean",
					"searchable": false
				},
				{
					"slug": "company_logo",
					"label": "Company Logo",
					"type": "image",
					"searchable": false
				},
				{
					"slug": "apply_url",
					"label": "Apply URL",
					"type": "string",
					"searchable": false
				}
			]
		},
		{
			"slug": "pages",
			"label": "Pages",
			"labelSingular": "Page",
			"supports": ["drafts", "revisions", "search"],
			"fields": [
				{
					"slug": "title",
					"label": "Title",
					"type": "string",
					"required": true,
					"searchable": true
				},
				{
					"slug": "content",
					"label": "Content",
					"type": "portableText",
					"searchable": true
				}
			]
		}
	],

	"taxonomies": [
		{
			"name": "category",
			"label": "Categories",
			"labelSingular": "Category",
			"hierarchical": true,
			"collections": ["jobs"],
			"terms": [
				{ "slug": "engineering", "label": "Engineering" },
				{ "slug": "design", "label": "Design" },
				{ "slug": "product", "label": "Product" },
				{ "slug": "data", "label": "Data" },
				{ "slug": "devops", "label": "DevOps & Infrastructure" },
				{ "slug": "security", "label": "Security" },
				{ "slug": "marketing", "label": "Marketing" },
				{ "slug": "sales", "label": "Sales" }
			]
		},
		{
			"name": "job_type",
			"label": "Job Types",
			"labelSingular": "Job Type",
			"hierarchical": false,
			"collections": ["jobs"],
			"terms": [
				{ "slug": "full-time", "label": "Full-time" },
				{ "slug": "part-time", "label": "Part-time" },
				{ "slug": "contract", "label": "Contract" },
				{ "slug": "freelance", "label": "Freelance" }
			]
		}
	],

	"menus": [
		{
			"name": "primary",
			"label": "Primary Navigation",
			"items": [
				{ "type": "custom", "label": "Find Jobs", "url": "/jobs" },
				{ "type": "custom", "label": "Companies", "url": "/jobs/companies" },
				{ "type": "custom", "label": "About", "url": "/pages/about" }
