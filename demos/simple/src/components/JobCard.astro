---
interface Props {
	title: string;
	company: string;
	location: string;
	salary?: string;
	type: string;
	category: string;
	experienceLevel?: string;
	isRemote: boolean;
	tags?: string[];
	companyLogo?: string;
	href: string;
	postedAt?: Date;
}

const {
	title,
	company,
	location,
	salary,
	type: jobType,
	category,
	experienceLevel,
	isRemote,
	tags,
	companyLogo,
	href,
	postedAt,
} = Astro.props;

const formattedDate = postedAt
	? timeAgo(postedAt)
	: null;

function timeAgo(date: Date): string {
	const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
	const intervals: [number, string][] = [
		[31536000, "year"],
		[2592000, "month"],
		[604800, "week"],
		[86400, "day"],
		[3600, "hour"],
		[60, "minute"],
	];
	for (const [secs, label] of intervals) {
		const count = Math.floor(seconds / secs);
		if (count >= 1) {
			return `${count} ${label}${count > 1 ? "s" : ""} ago`;
		}
	}
	return "Just now";
}

const typeLabels: Record<string, string> = {
	"full-time": "Full-time",
	"part-time": "Part-time",
	"contract": "Contract",
	"freelance": "Freelance",
};

function getTypeVariant(type: string): string {
	switch (type) {
		case "full-time": return "success";
		case "contract": return "warning";
		case "freelance": return "info";
		case "part-time": return "info";
		default: return "secondary";
	}
}
---

<article class="job-card">
	<a href={href} class="job-card-link" aria-label={`${title} at ${company}, ${location}`}>
		<div class="job-card-body">
			<div class="job-card-header">
				{companyLogo && (
					<div class="job-card-logo">
						<img src={companyLogo} alt={`${company} logo`} width="48" height="48" loading="lazy" />
					</div>
				)}
				<div class="job-card-title-group">
					<h3 class="job-card-title">{title}</h3>
					<p class="job-card-company">{company}</p>
				</div>
			</div>

			<div class="job-card-details">
				<div class="job-card-detail">
					<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
					<span>{location}</span>
				</div>
				{salary && (
					<span class="job-card-salary">{salary}</span>
				)}
			</div>

			<div class="job-card-badges">
				<span class={`job-badge badge-${getTypeVariant(jobType)}`} aria-label={`${typeLabels[jobType] || jobType} position`}>
					{typeLabels[jobType] || jobType}
				</span>
				{isRemote && (
					<span class="job-badge badge-info" aria-label="Remote position">
						<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
						Remote
					</span>
				)}
				{experienceLevel && (
					<span class="job-badge badge-secondary">{experienceLevel}</span>
				)}
			</div>
		</div>

		<div class="job-card-footer">
			{tags && tags.length > 0 && (
				<div class="job-card-tags">
					{tags.slice(0, 3).map(tag => (
						<span class="job-tag">{tag}</span>
					))}
					{tags.length > 3 && (
						<span class="job-tag job-tag-more">+{tags.length - 3}</span>
					)}
				</div>
			)}
			{formattedDate && (
				<span class="job-card-time">{formattedDate}</span>
			)}
		</div>
	</a>
</article>

<style>
	.job-card {
		background: var(--color-surface-elevated);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		transition: box-shadow var(--transition-base), border-color var(--transition-base);
		overflow: hidden;
	}

	.job-card:hover {
		box-shadow: var(--shadow-md);
		border-color: var(--color-accent-ring);
	}

	.job-card-link {
		display: flex;
		flex-direction: column;
		padding: var(--spacing-5);
		text-decoration: none;
		color: inherit;
		height: 100%;
		gap: var(--spacing-3);
	}

	.job-card-body {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-3);
		flex: 1;
	}

	.job-card-header {
		display: flex;
		align-items: flex-start;
		gap: var(--spacing-3);
	}

	.job-card-logo {
		width: 48px;
		height: 48px;
		border-radius: var(--radius);
		overflow: hidden;
		background: var(--color-surface);
		flex-shrink: 0;
	}

	.job-card-logo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.job-card-title-group {
		flex: 1;
		min-width: 0;
	}

	.job-card-title {
		font-size: var(--font-size-lg);
		font-weight: 600;
		color: var(--color-text);
		line-height: var(--leading-snug);
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color var(--transition-fast);
	}

	.job-card:hover .job-card-title {
		color: var(--color-accent);
	}

	.job-card-company {
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
		margin-top: 2px;
	}

	.job-card-details {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-3);
	}

	.job-card-detail {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
		font-size: var(--font-size-sm);
		color: var(--color-text-secondary);
	}

	.job-card-detail svg {
		flex-shrink: 0;
		color: var(--color-muted);
	}

	.job-card-salary {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-success);
		white-space: nowrap;
	}

	.job-card-badges {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-2);
	}

	.job-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-1);
		padding: 2px var(--spacing-2);
		font-size: var(--font-size-xs);
		font-weight: 500;
		border-radius: 999px;
		line-height: 1.4;
	}

	.badge-success {
		background: color-mix(in srgb, var(--color-success) 10%, transparent);
		color: var(--color-success);
	}

	.badge-warning {
		background: color-mix(in srgb, var(--color-warning) 10%, transparent);
		color: var(--color-warning);
	}

	.badge-info {
		background: color-mix(in srgb, var(--color-info) 10%, transparent);
		color: var(--color-info);
	}

	.badge-secondary {
		background: var(--color-surface);
		color: var(--color-text-secondary);
	}

	.job-card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--spacing-3);
		padding-top: var(--spacing-3);
		border-top: 1px solid var(--color-border-subtle);
	}

	.job-card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-1);
		flex: 1;
		min-width: 0;
	}

	.job-tag {
		display: inline-block;
		padding: 1px var(--spacing-2);
		font-size: var(--font-size-xs);
		color: var(--color-text-secondary);
		background: var(--color-surface);
		border-radius: var(--radius);
		white-space: nowrap;
	}

	.job-tag-more {
		color: var(--color-muted);
		font-size: var(--font-size-xs);
	}

	.job-card-time {
		font-size: var(--font-size-xs);
		color: var(--color-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	@media (min-width: 1024px) {
		.job-card-link {
			padding: var(--spacing-6);
		}
	}
</style>
