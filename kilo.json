{
	"$schema": "https://app.kilo.ai/config.json",
	"mcp": {
		"github": {
			"type": "local",
			"command": ["npx", "-y", "@modelcontextprotocol/server-github"],
			"environment": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
			},
			"enabled": true
		},
		"openviking": {
			"type": "local",
			"command": [
				"/opt/homebrew/bin/python3.13",
				".kilo/mcp/openviking_server.py"
			],
			"environment": {
				"OPENVIKING_API_URL": "http://localhost:1933",
				"OPENVIKING_API_KEY": "${OPENVIKING_API_KEY}"
			},
			"enabled": true
		}
	},
	"skills": {
		"paths": ["./skills", "./.claude/skills"]
	},
	"permission": {
		"switch_mode": "allow"
	}
}
